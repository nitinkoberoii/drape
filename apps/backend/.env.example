PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info
# Comma-separated browser origins. Leave empty for the extension's privileged fetches.
CORS_ALLOWED_ORIGINS=
AI_SERVICE_URL=http://localhost:8000
# Required to enable protected endpoints. Create a Supabase project first.
SUPABASE_URL=
SUPABASE_JWT_AUDIENCE=authenticated

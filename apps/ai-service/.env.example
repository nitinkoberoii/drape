AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000
# Legacy default used by both thresholds when the explicit variables are absent.
CONFIDENCE_THRESHOLD=0.5
# Keep the production default conservative. Override per /analyze request for evaluation.
DETECTION_CONFIDENCE_THRESHOLD=0.5
TEXT_CONFIDENCE_THRESHOLD=0.5
# Suppress same-category boxes with overlap at or above this value.
DUPLICATE_IOU_THRESHOLD=0.6
# Fractional padding around each detected person before garment detection.
PERSON_CROP_PADDING=0.1
# Maximum pixel dimension for opt-in debug PNGs and the number of item crops per person.
DEBUG_VISUAL_MAX_DIMENSION=768
DEBUG_VISUAL_MAX_ITEMS_PER_PERSON=12
MAX_IMAGE_DIMENSION=1536
# Override these only when using a compatible, self-hosted Hugging Face checkpoint.
DETECTOR_MODEL_ID=IDEA-Research/grounding-dino-base
SEGMENTER_MODEL_ID=facebook/sam2-hiera-small

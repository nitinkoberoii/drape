{
  "name": "@drape/extension",
  "version": "0.1.0",
  "private": true,
  "manifest": {
    "name": "Drape",
    "permissions": [
      "storage",
      "tabs"
    ],
    "host_permissions": [
      "*://*.youtube.com/*",
      "*://youtu.be/*",
      "*://*.netflix.com/*",
      "*://*.primevideo.com/*",
      "*://*.instagram.com/*",
      "*://*.tiktok.com/*"
    ]
  },
  "scripts": {
    "build": "plasmo build",
    "dev": "plasmo dev",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@drape/shared-types": "workspace:*",
    "@plasmohq/storage": "^1.15.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/chrome": "^0.2.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "typescript": "^5.8.3",
    "vitest": "3.2.4"
  }
}
